      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (host) (node_systemd_units{host=~\"$host\"})",
          "legendFormat": "{{host}}",
