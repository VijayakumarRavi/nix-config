      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(30, time() - (systemd_unit_active_enter_time_seconds{host=~\"$host\", name=~\".*\\\\.service\", name!~\"user@.*|session-.*\"} > 0))",
          "legendFormat": "{{name}}",
          "range": true,
          "refId": "A"
