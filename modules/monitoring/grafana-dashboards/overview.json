    {
      "id": 5,
      "title": "Fail2Ban Active Blocks",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(fail2ban_banned_current{instance=~\"$host\"}) or vector(0)",
          "legendFormat": "Banned IPs",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
